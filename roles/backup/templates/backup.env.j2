# Excalibur restic backup configuration.
# This file is intentionally created on the host only and must not be committed.
# Mode: 0600 root:root.

# Synology/NAS over SSH example:
# RESTIC_REPOSITORY=sftp:backup-user@nas-host:/volume1/backups/excalibur-restic
RESTIC_REPOSITORY=

# Generate with: openssl rand -base64 48
RESTIC_PASSWORD=

# Optional: initialize the repository automatically during the first backup.
RESTIC_INIT_REPOSITORY=false

# Optional: pass a dedicated SSH identity for the NAS backup user.
# RESTIC_SFTP_COMMAND=ssh -i /etc/excalibur/backup_ed25519 -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new

